# Required: Personal Access Token from https://www.figma.com/developers/api#access-tokens
# Required scopes: file_content:read, file_metadata:read
FIGMA_ACCESS_TOKEN=figd_REPLACE_WITH_YOUR_REAL_TOKEN

# Optional overrides
# APP_NAME=Figma Scraper API
# API_V1_PREFIX=/api/v1
# ENV=development
# FIGMA_API_URL=https://api.figma.com/v1
# FIGMA_API_MAX_RETRY_WAIT_SECONDS=10

